
{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "Property Analyzer",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(html|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "functions": [{ "source": "functions" }]
}
